{
  "name": "@web-gis/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "lint:contracts": "spectral lint --ruleset ../../.spectral.yaml ../api/openapi.yaml",
    "generate:contracts": "openapi-typescript ../api/openapi.yaml -o src/contracts/generated.ts",
    "check:contracts-drift": "bash ../../scripts/check-contract-drift.sh"
  },
  "dependencies": {
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-router": "1.170.16",
    "lucide-react": "^0.468.0",
    "maplibre-gl": "^5.24.0",
    "oidc-client-ts": "^3.5.0",
    "openapi-fetch": "0.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-oidc-context": "^3.3.1"
  },
  "devDependencies": {
    "@stoplight/spectral-cli": "^6.16.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.6.3",
    "vite": "^8.1.2"
  }
}
