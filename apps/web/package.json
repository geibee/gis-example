{
  "name": "@web-gis/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint:contracts": "spectral lint --ruleset ../../.spectral.yaml ../api/openapi.yaml",
    "generate:contracts": "openapi-typescript ../api/openapi.yaml -o src/contracts/generated.ts",
    "check:contracts-drift": "bash ../../scripts/check-contract-drift.sh"
  },
  "dependencies": {
    "@hookform/resolvers": "5.4.0",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-router": "1.170.16",
    "lucide-react": "^0.468.0",
    "maplibre-gl": "^5.24.0",
    "oidc-client-ts": "^3.5.0",
    "openapi-fetch": "0.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "7.80.0",
    "react-oidc-context": "^3.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@stoplight/spectral-cli": "^6.16.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "4.1.9",
    "jsdom": "29.1.1",
    "msw": "2.14.6",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "4.1.9"
  }
}
