# infra/.env.example — ローカル開発 (docker compose) 用の資格情報テンプレート
#
#   cp infra/.env.example infra/.env
#
# でコピーしてから `docker compose -f infra/docker-compose.yml up --build` する。
# 実 .env は gitignore 済み。値を変えても動くが、ここの既定値はローカル開発専用の
# 弱い資格情報であり、本番では一切使わないこと。
# 本番のシークレットの正本は AWS Secrets Manager (docs/environment-variables.md 参照)。

# PostgreSQL (postgres / seed / martin / api / worker-gis が共有)
POSTGRES_DB=gis
POSTGRES_USER=gis
POSTGRES_PASSWORD=gis

# Keycloak bootstrap admin (管理コンソール http://localhost:8081)
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=admin

# アップロードの保存先 (docs/environment-variables.md 参照)。
# 既定 local はホスト volume 共有 (従来動作)。S3 経路を試す場合は s3 にして
# `docker compose -f infra/docker-compose.yml --profile s3 up --build` で MinIO ごと起動する
#UPLOAD_STORAGE=s3
#S3_BUCKET=gis-uploads
#S3_REGION=us-east-1

# MinIO (--profile s3 のときのみ使用)。api / worker の AWS 認証情報としても配線される
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio-secret

# ホスト側ポートが競合する場合のみ変更する
#POSTGRES_HOST_PORT=5432
#WEB_HOST_PORT=5173
